{
  "name": "vscode-webview-starter-kit",
  "version": "2.0.0",
  "publisher": "tnaum-ms",
  "displayName": "VS Code Webview Starter Kit",
  "description": "A reference app demonstrating VS Code webviews with tRPC, React, Fluent UI, and adaptive theming.",
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "categories": [
    "Other"
  ],
  "keywords": [
    "webview",
    "tRPC",
    "React",
    "Fluent UI",
    "starter-kit"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnaum-ms/vscode-webview-starter-kit"
  },
  "main": "./main",
  "l10n": "./l10n",
  "activationEvents": [
    "*"
  ],
  "scripts": {
    "build": "tsc",
    "compile": "tsc -watch",
    "package": "run-script-os",
    "package:win32": "npm run webpack-prod && cd dist && npm pkg delete \"scripts.vscode:prepublish\" && npx vsce package --no-dependencies --out ../%npm_package_name%-%npm_package_version%.vsix",
    "package:default": "npm run webpack-prod && cd dist && npm pkg delete \"scripts.vscode:prepublish\" && npx vsce package --no-dependencies --out ../${npm_package_name}-${npm_package_version}.vsix",
    "package-prerelease": "run-script-os",
    "package-prerelease:win32": "npm run webpack-prod && cd dist && npm pkg delete \"scripts.vscode:prepublish\" && npx vsce package --pre-release --no-dependencies --out ../%npm_package_name%-%npm_package_version%-pre-release.vsix",
    "package-prerelease:default": "npm run webpack-prod && cd dist && npm pkg delete \"scripts.vscode:prepublish\" && npx vsce package --pre-release --no-dependencies --out ../${npm_package_name}-${npm_package_version}-pre-release.vsix",
    "lint": "eslint --quiet .",
    "lint-fix": "eslint . --fix",
    "prettier": "prettier -c \"(src|l10n)/**/*.@(js|ts|jsx|tsx|json)\" \"./*.@(js|ts|jsx|tsx|json)\"",
    "prettier-fix": "prettier -w \"(src|l10n)/**/*.@(js|ts|jsx|tsx|json)\" \"./*.@(js|ts|jsx|tsx|json)\"",
    "test": "jest",
    "webpack-dev": "rimraf ./dist && npm run webpack-dev-ext && npm run webpack-dev-wv",
    "webpack-prod": "rimraf ./dist && npm run webpack-prod-ext && npm run webpack-prod-wv",
    "webpack-dev-ext": "webpack --mode development --config ./webpack.config.ext.js",
    "webpack-dev-wv": "webpack --mode development --config ./webpack.config.views.js",
    "webpack-prod-ext": "webpack --mode production --config ./webpack.config.ext.js",
    "webpack-prod-wv": "webpack --mode production --config ./webpack.config.views.js",
    "watch:ext": "webpack --mode development --config ./webpack.config.ext.js --watch",
    "watch:views": "webpack serve --mode development --config ./webpack.config.views.js",
    "l10n": "node l10n/scripts/build.l10n.mjs",
    "l10n:check": "node l10n/scripts/check.l10n.mjs"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.1",
    "@pmmmwh/react-refresh-webpack-plugin": "~0.6.1",
    "@swc/cli": "~0.7.8",
    "@swc/core": "~1.15.1",
    "@swc/jest": "~0.2.39",
    "@types/jest": "~30.0.0",
    "@types/node": "~22.18.13",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.2",
    "@types/vscode": "~1.96.0",
    "@types/vscode-webview": "~1.57.5",
    "@vscode/l10n-dev": "~0.0.35",
    "@vscode/vsce": "~3.7.0",
    "copy-webpack-plugin": "~13.0.1",
    "cross-env": "~7.0.3",
    "css-loader": "~7.1.2",
    "eslint": "~9.39.1",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jest": "~29.1.0",
    "eslint-plugin-license-header": "~0.8.0",
    "glob": "~12.0.0",
    "globals": "~16.5.0",
    "jest": "~30.2.0",
    "jest-mock-vscode": "~4.0.5",
    "monaco-editor-webpack-plugin": "~7.1.1",
    "prettier": "~3.6.2",
    "prettier-plugin-organize-imports": "~4.3.0",
    "react": "~19.2.0",
    "react-dom": "~19.2.0",
    "react-refresh": "~0.18.0",
    "rimraf": "~6.1.0",
    "run-script-os": "^1.1.6",
    "sass": "~1.94.1",
    "sass-loader": "~16.0.6",
    "style-loader": "~4.0.0",
    "swc-loader": "~0.2.6",
    "terser-webpack-plugin": "~5.3.14",
    "ts-jest": "~29.4.5",
    "ts-node": "~10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.47.0",
    "webpack": "~5.105.0",
    "webpack-bundle-analyzer": "~5.0.0",
    "webpack-cli": "~6.0.1",
    "webpack-dev-server": "~5.2.2"
  },
  "dependencies": {
    "@fluentui/react-components": "~9.72.3",
    "@fluentui/react-icons": "~2.0.313",
    "@microsoft/vscode-ext-webview": "~0.9.1",
    "@monaco-editor/react": "~4.7.0",
    "@trpc/client": "~11.10.0",
    "@trpc/server": "~11.10.0",
    "@vscode/l10n": "~0.0.18",
    "es-toolkit": "~1.42.0",
    "monaco-editor": "~0.52.2",
    "zod": "~4.1.12"
  },
  "overrides": {
    "glob": "~12.0.0",
    "@fluentui/react-components": {
      "@types/react": "~19.2.2"
    }
  },
  "extensionDependencies": [],
  "contributes": {
    "commands": [
      {
        "command": "webviewStarter.openMainView",
        "title": "Open Main View",
        "category": "Webview Starter Kit"
      },
      {
        "command": "webviewStarter.openBasicView",
        "title": "Open Basic View",
        "category": "Webview Starter Kit"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "webviewStarter.openMainView"
        },
        {
          "command": "webviewStarter.openBasicView"
        }
      ]
    }
  }
}
